{
  "manifest_version": "0.3",
  "name": "saferagenticai-mcp",
  "display_name": "Safer Agentic AI",
  "version": "0.3.3",
  "description": "Read-only tools over the Safer Agentic AI framework: 238 patterns + 14 heuristics.",
  "author": {
    "name": "Nell Watson",
    "url": "https://www.saferagenticai.org"
  },
  "homepage": "https://www.saferagenticai.org",
  "documentation": "https://github.com/NellInc/SaferAgenticAI/tree/main/research/mcp",
  "license": "MIT",
  "keywords": [
    "ai-safety",
    "agentic-ai",
    "mcp",
    "governance",
    "framework"
  ],
  "server": {
    "type": "python",
    "entry_point": "server/main.py",
    "mcp_config": {
      "command": "python",
      "args": [
        "${__dirname}/server/main.py"
      ],
      "env": {
        "PYTHONPATH": "${__dirname}/server/lib"
      }
    }
  },
  "compatibility": {
    "runtimes": {
      "python": ">=3.10"
    }
  }
}
